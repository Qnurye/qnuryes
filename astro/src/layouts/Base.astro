---
import '@/styles/global.css';
import GoogleAnalytics from '@astro-kits/google-analytics';
import Footer from '@/components/Footer.astro';
import Nav from '@/components/Nav.astro';
import { Toaster } from '@/components/ui/sonner';
import { stripMarkdown } from '@/lib/seo';
import { cn } from '@/lib/utils';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  className?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  noIndex?: boolean;
  tags?: string[];
}

const {
  title,
  className,
  description,
  keywords,
  image,
  imageAlt,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'Qnurye',
  noIndex = false,
  tags = [],
} = Astro.props;

const pageTitle = title || "Qnury.e's";
const defaultDescription = "Qnury.e's is the personal website of Qnurye";
const pageDescription = stripMarkdown(description || defaultDescription) || defaultDescription;
const siteUrl = Astro.site?.origin || 'https://qnury.es';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const pageKeywords = (keywords || '')
  .split(',')
  .map((keyword: string) => keyword.trim())
  .concat(
    'Qnurye, Qnury.e, Qnury, query.e, qnury, qnury.e, qnury-e, qnury_e, qnury_e_, qnurye, Astro, Next.js,' +
      ' React, Vue, Svelte, Python, Rust, Golang, C++, C#, Java, Kotlin, Dart, Flutter, WebAssembly, WebGPU, WebGL,' +
      ' OpenGL, Vulkan, DirectX, Metal, OpenCL, CUDA',
  )
  .join(', ');

// Resolve OG image to absolute URL
const ogImage = image ? new URL(image, siteUrl).href : undefined;

// Locale mapping for OG
const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  'zh-cn': 'zh_CN',
  'zh-tw': 'zh_TW',
};
const currentLocale = Astro.currentLocale || 'en';
const ogLocale = ogLocaleMap[currentLocale] || 'en_US';
const alternateLocales = Object.entries(ogLocaleMap)
  .filter(([key]) => key !== currentLocale)
  .map(([, value]) => value);

// All locales for hreflang
const allLocales = ['en', 'zh-cn', 'zh-tw'];
---

<!doctype html>
<html lang={Astro.currentLocale}>
  <head>

    <!-- High Priority -->
    <title>{pageTitle}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Arvo:ital,wght@0,400;0,700;1,400;1,700&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&family=Baskervville:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.cn" />
    <link rel="preconnect" href="https://fonts.gstatic.cn" crossorigin />
    <link
      href="https://fonts.googleapis.cn/css2?family=Arvo:ital,wght@0,400;0,700;1,400;1,700&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&family=Baskervville:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <!-- CJK fonts: self-hosted -->
    <link rel="stylesheet" href="/fonts/lxgw-neo-xihei/result.css" />
    <link rel="stylesheet" href="/fonts/genryumin/result.css" />
    <!-- Maple Mono CN -->
    <link rel="stylesheet" href="https://chinese-fonts-cdn.deno.dev/packages/maple-mono-cn/dist/MapleMono-CN-Regular/result.css" />

    <link
      rel="preload"
      href="https://cdn.jsdelivr.net/fontsource/fonts/maple-mono@latest/latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- SEO -->
    <meta name="author" content={author} />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    {allLocales.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={new URL(Astro.url.pathname.replace(`/${currentLocale}`, `/${loc}`), siteUrl).href}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(Astro.url.pathname.replace(`/${currentLocale}`, '/en'), siteUrl).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Qnury.e's" />
    <meta property="og:locale" content={ogLocale} />
    {alternateLocales.map((loc) => (
      <meta property="og:locale:alternate" content={loc} />
    ))}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content={imageAlt || pageTitle} />}

    <!-- Article-specific OG -->
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {type === 'article' && <meta property="article:author" content={author} />}
    {type === 'article' && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image:alt" content={imageAlt || pageTitle} />}

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={pageTitle}
      href={`/${currentLocale}/rss.xml`}
    />

    <!-- Structured Data -->
    <slot name="jsonLd" />

    <!-- Google tag (gtag.js) -->
    <GoogleAnalytics />

  </head>
  <body class="px-1 sm:px-2 md:px-4 lg:px-8 size-full">
    <Nav />
    <main class={cn(className, 'min-h-screen scroll-smooth max-w-full px-4 sm:px-6 md:px-12 lg:px-24')}>
      <slot />
    </main>
    <Footer />
    <Toaster client:load />
  </body>
</html>

<script is:inline>
  // eslint-disable-next-line @typescript-eslint/explicit-function-return-type
  const getThemePreference = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };
  const isDark = getThemePreference() === 'dark';
  document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

  if (typeof localStorage !== 'undefined') {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }
</script>
