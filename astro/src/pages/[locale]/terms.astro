---
import { Markdown } from 'astro-remote';
import AskAiExplain from '@/components/AskAiExplain.astro';
import { loadTranslations } from '@/i18n';
import Base from '@/layouts/Base.astro';

export { getI18nPaths as getStaticPaths } from '@/i18n';

const locale = Astro.currentLocale || 'en';
const t = await loadTranslations(locale);

const contentFiles = import.meta.glob<string>('../../data/legal/tos-*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const content = contentFiles[`../../data/legal/tos-${locale}.md`] || contentFiles['../../data/legal/tos-en.md'];
---

<Base
  title={t('tos.page_title')}
  description={t('tos.page_description')}
>
  <article class="max-w-3xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-serif font-black leading-tight mb-2">{t('tos.title')}</h1>
      <p class="text-sm text-muted-foreground">{t('tos.effective_date')}</p>
    </header>
    <AskAiExplain documentType="terms" locale={locale} />
    <div class="prose max-w-none space-y-4">
      <Markdown content={content} />
    </div>
  </article>
</Base>
