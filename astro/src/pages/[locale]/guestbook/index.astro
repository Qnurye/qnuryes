---
import GuestbookForm from '@/components/Guestbook/GuestbookForm';
import GuestbookWall from '@/components/Guestbook/GuestbookWall';
import { loadTranslations } from '@/i18n';
import Base from '@/layouts/Base.astro';

export { getI18nPaths as getStaticPaths } from '@/i18n';

const locale = Astro.currentLocale || 'en';
const t = await loadTranslations(locale);
---

<Base
  title={t('guestbook.wall.title')}
  description={t('guestbook.description')}
  className="flex flex-col gap-8"
>
  <div class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="font-serif text-4xl">{t('guestbook.wall.title')}</h1>
      <GuestbookForm client:load locale={locale} />
    </div>
    <GuestbookWall client:load locale={locale} />
    <p class="mt-8 text-center text-sm text-muted-foreground">
      {t('guestbook.wall.footer_removal', { email: '' })}
      <a href="mailto:me@qnury.es" class="underline">me@qnury.es</a>
    </p>
  </div>
</Base>
