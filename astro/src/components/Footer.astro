---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { Markdown } from 'astro-remote';
import tail from '@/assets/tail.svg';
import { loadTranslations } from '@/i18n';
import Newsletter from './Newsletter';

const locale = Astro.currentLocale || 'en';
const t = await loadTranslations(locale);
---

<footer class="pt-8 px-2 mt-16 flex flex-col gap-4 border-t">
  <div class="flex flex-col sm:flex-row justify-between gap-6">
    <div class="flex flex-col gap-4 items-start">
      <Newsletter locale={locale} client:load />
      <div class="flex gap-4 text-xs text-muted-foreground">
        <a
          href={`/${locale}/rss.xml`}
          class="hover:text-foreground transition-colors underline underline-offset-2"
        >
          {t('footer.rss')}
        </a>
        <a
          href="https://github.com/Qnurye/qnuryes"
          class="hover:text-foreground transition-colors underline underline-offset-2"
        >
          {t('footer.source_code')}
        </a>
        <a href={getRelativeLocaleUrl(locale, 'terms')} class="hover:text-foreground transition-colors underline underline-offset-2">
          {t('footer.tos')}
        </a>
        <a href={getRelativeLocaleUrl(locale, 'privacy')} class="hover:text-foreground transition-colors underline underline-offset-2">
          {t('footer.privacy')}
        </a>
      </div>
    </div>
    <div class="flex flex-col items-start sm:items-end sm:justify-end gap-1 text-sm">
      <span class="flex gap-1 text-xs text-muted-foreground items-center">
        &copy; <span id="footer-year"></span> {t('footer.all_rights_reserved')}
      </span>
      <span class="font-mono">
        <Markdown content={t('footer.credits')} />
      </span>
    </div>
  </div>
  <div class="w-full flex flex-row justify-center gap-8 h-2 overflow-auto">
    {Array(12).fill({}).map((_, __) =>
      (<Image src={tail} alt="" />),
    )}
  </div>
</footer>

<style is:global>
  @property --glow-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes mailbox-wiggle {
    0%, 100% { transform: rotate(0deg) translateY(0); }
    10% { transform: rotate(-14deg) translateY(-2px); }
    20% { transform: rotate(10deg) translateY(-1px); }
    30% { transform: rotate(-10deg) translateY(-2px); }
    40% { transform: rotate(8deg) translateY(-1px); }
    50% { transform: rotate(-4deg); }
    60% { transform: rotate(2deg); }
  }

  .newsletter-trigger:hover .newsletter-icon {
    animation: mailbox-wiggle 0.7s cubic-bezier(0.36, 0.07, 0.19, 0.97);
  }

  .newsletter-spotlight {
    position: fixed;
    inset: 0;
    z-index: 40;
    pointer-events: none;
    background: rgba(0, 0, 0, 0.85);
    opacity: 0;

    -webkit-mask-image:
      radial-gradient(circle at var(--s1x, 0px) var(--s1y, 0px),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s2x, 100vw) var(--s2y, 0px),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s3x, 0px) var(--s3y, 100vh),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s4x, 100vw) var(--s4y, 100vh),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px));
    mask-image:
      radial-gradient(circle at var(--s1x, 0px) var(--s1y, 0px),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s2x, 100vw) var(--s2y, 0px),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s3x, 0px) var(--s3y, 100vh),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px)),
      radial-gradient(circle at var(--s4x, 100vw) var(--s4y, 100vh),
        transparent var(--sr, 1000px), black calc(var(--sr, 1000px) + 50px));

    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }

  /* --- Container: slides in from the right (dark zone → illuminated zone) --- */
  @keyframes slide-in-click-it {
    0% {
      opacity: 0;
      transform: translateY(-50%) translateX(100px);
      filter: blur(6px);
    }
    40% {
      opacity: 1;
      filter: blur(0);
    }
    100% {
      opacity: 1;
      transform: translateY(-50%) translateX(8px);
      filter: blur(0);
    }
  }

  /* --- Individual letter: fade-up with deblur --- */
  @keyframes click-it-letter-in {
    from {
      opacity: 0;
      transform: translateY(5px);
      filter: blur(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  /* --- Arrow: bouncing pulse after settling --- */
  @keyframes arrow-bounce {
    0%, 100% {
      transform: translateX(0);
      opacity: 1;
    }
    50% {
      transform: translateX(-5px);
      opacity: 0.7;
    }
  }

  /* Continuous rotation of the gradient around the border */
  @keyframes glow-rotate {
    from { --glow-angle: 0deg; }
    to { --glow-angle: 360deg; }
  }

  /* Breathing pulse on the outer glow shadow */
  @keyframes glow-breathe {
    0%, 100% {
      box-shadow:
        0 0 8px 2px oklch(0.7 0.2 0 / 0.3),
        0 0 16px 4px oklch(0.7 0.2 150 / 0.15);
    }
    50% {
      box-shadow:
        0 0 14px 4px oklch(0.7 0.2 270 / 0.5),
        0 0 28px 8px oklch(0.7 0.2 60 / 0.25);
    }
  }

  .click-it-text {
    animation: slide-in-click-it 600ms cubic-bezier(0.22, 1, 0.36, 1) both;
    text-shadow: 0 0 8px oklch(1 0 0 / 0.4);
  }

  .click-it-letter {
    display: inline-block;
    opacity: 0;
    animation: click-it-letter-in 300ms cubic-bezier(0.22, 1, 0.36, 1) both;
    /* animation-delay set inline via style prop */
  }

  .click-it-arrow {
    display: inline-block;
    animation: arrow-bounce 1s ease-in-out 800ms infinite;
    text-shadow: 0 0 10px oklch(1 0 0 / 0.6);
  }

  .newsletter-trigger {
    position: relative;
    isolation: isolate;
    transition: border-color 0.3s ease, box-shadow 0.5s ease;
  }

  .newsletter-trigger::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: calc(var(--radius-md) + 3px);
    background: conic-gradient(
      from var(--glow-angle),
      oklch(0.7 0.25 30),
      oklch(0.8 0.2 80),
      oklch(0.75 0.2 150),
      oklch(0.7 0.2 230),
      oklch(0.65 0.25 290),
      oklch(0.7 0.25 340),
      oklch(0.7 0.25 30)
    );
    z-index: -2;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .newsletter-trigger::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    background: var(--background);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .newsletter-glow {
    border-color: transparent !important;
    animation: glow-breathe 2s ease-in-out infinite;
  }

  .newsletter-glow::before {
    animation: glow-rotate 3s linear infinite;
  }

  .newsletter-glow::before,
  .newsletter-glow::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .newsletter-trigger:hover .newsletter-icon {
      animation: none;
    }
    .newsletter-spotlight {
      transition: none;
    }
    .click-it-text {
      animation: none;
    }
    .click-it-letter {
      animation: none;
      opacity: 1;
    }
    .click-it-arrow {
      animation: none;
    }
    .newsletter-glow {
      animation: none;
      border-color: oklch(0.7 0.2 270) !important;
      box-shadow: 0 0 8px 2px oklch(0.7 0.2 270 / 0.3);
    }
    .newsletter-glow::before {
      animation: none;
      --glow-angle: 135deg;
      opacity: 0;
    }
  }
</style>

<script>
  document.getElementById('footer-year')!.textContent = new Date().getFullYear().toString();
</script>
